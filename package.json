{
  "name": "face-gallery",
  "private": true,
  "version": "0.1.0",
  "description": "Offline desktop app to organize photos by person using local face recognition",
  "author": "mushitori",
  "license": "MIT",
  "keywords": [
    "desktop app",
    "face detection",
    "face gallery",
    "face recognition",
    "fastapi",
    "insightface",
    "local-first",
    "offline",
    "photo gallery",
    "photo organizer",
    "privacy",
    "sqlite",
    "tauri",
    "vue"
  ],
  "scripts": {
    "dev:api": "powershell -ExecutionPolicy Bypass -File backend/scripts/dev.ps1",
    "dev:ui": "pnpm --dir frontend dev",
    "build:ui": "pnpm --dir frontend build",
    "tauri:dev": "pnpm exec tauri dev",
    "tauri:build": "pnpm exec tauri build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2"
  }
}
